# Общие настройки
APP_ENV=local

# Auth Service
AUTH_CONFIG_PATH=config/localConfig.yaml
#localhost
AUTH_SERVICE_HOST=auth_service
AUTH_SERVICE_PORT=50051
#localhost
AUTH_DB_HOST=pg_service_auth
AUTH_DB_PORT=5432
AUTH_DB_USER=authAdminUser
AUTH_DB_PASSWORD=authAdminUserPassword
AUTH_DB_NAME=authDB

# JWT
JWT_SECRET=tEsTjWtSeCrEt
JWT_TTL=1h
JWT_REFRESH_TTL=24h

# Redis
#localhost
REDIS_HOST=redis_service
REDIS_PORT=6379
REDIS_PASSWORD=

# Wishlist Service
WISHLIST_CONFIG_PATH=config/localConfig.yaml
#localhost
WISHLIST_SERVICE_HOST=wishlist_service
WISHLIST_SERVICE_PORT=50052
#localhost
WISHLIST_DB_HOST=pg_service_wishlist
WISHLIST_DB_PORT=5433
WISHLIST_DB_USER=wishlistAdminUser
WISHLIST_DB_PASSWORD=wishlistAUP
WISHLIST_DB_NAME=wishlistDB

# Kafka
#localhost
KAFKA_BROKER_URL=kafka
KAFKA_BROKER_PORT=9092
KAFKA_TOPIC_WISHLIST_EVENTS=wishlist_events

# API GATEWAY
API_GATEWAY_CONFIG_PATH=config/localConfig.yaml
#localhost
API_GATEWAY_HTTP_ADRESS=api_gateway_service
API_GATEWAY_HTTP_PORT=8095
API_GATEWAY_HTTP_TIMEOUT=5s

# CORS
ALLOWED_ORIGINS=http://localhost:8095
#,OPTIONS
ALLOWED_METHODS=GET,POST,PUT,DELETE
ALLOWED_HEADERS=Content-Type,Authorization,X-Trace-ID
CORS_ALLOW_CREDENTIALS=true

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_DURATION=60s


