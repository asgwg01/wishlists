# WEB_CLIENT
WEB_CLIENT_CONFIG_PATH=config/localConfig.yaml
WEB_CLIENT_HOST="localhost"
WEB_CLIENT_PORT=8090

# Log Bull
LOGBULL_URL=localhost#logbull
LOGBULL_PORT=4005
# Необходимо при первом запуске войти на http://localhost:4005 и создать проект, его id записываем тут
LOGBULL_PROJECT_ID=4b5a5d39-d27a-4138-8c8a-1b9adaf98159
LOGBULL_API_KEY=""


